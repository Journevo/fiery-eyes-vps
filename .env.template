# ============================================
# Fiery Eyes v2 — Environment Configuration
# Copy to .env and fill in values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postgres@localhost:5432/fiery_eyes

# --- API Keys ---
HELIUS_API_KEY=
COINGECKO_API_KEY=
ANTHROPIC_API_KEY=
ARTEMIS_API_KEY=
COINGLASS_API_KEY=
TOKENOMIST_API_KEY=
COINANK_API_KEY=
GROK_API_KEY=

# --- Reddit ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=fiery-eyes/2.0

# --- YouTube ---
YOUTUBE_API_KEY=

# --- Apify ---
APIFY_API_KEY=

# --- Telegram Bot (python-telegram-bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Multi-channel Telegram (v2) ---
# Falls back to TELEGRAM_CHAT_ID if not set
TELEGRAM_HFIRE_CHAT_ID=    # H-Fire channel (Tier 1-2 alerts)
TELEGRAM_HUOYAN_CHAT_ID=   # Huoyan channel (4-hourly pulse)
TELEGRAM_SYSTEM_CHAT_ID=   # System channel (diagnostics)

# --- Telegram Alpha (Telethon — user account) ---
# Required for KK Telegram parser
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=             # Your phone number with country code
KK_CHANNEL_ID=              # Krypto King channel/group numeric ID

# --- Scanner ---
SCAN_INTERVAL_MINUTES=30

# --- Shadow Mode ---
# true = log trades only, no real execution (default)
# false = live execution via Jupiter (NOT IMPLEMENTED YET)
SHADOW_MODE=true
