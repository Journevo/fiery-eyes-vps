[Unit]
Description=Fiery Eyes — Daily Snapshot Collection
After=network.target postgresql.service

[Service]
Type=oneshot
WorkingDirectory=/opt/fiery-eyes
ExecStart=/opt/fiery-eyes/venv/bin/python main.py snapshots
EnvironmentFile=/opt/fiery-eyes/.env
User=fiery-eyes
StandardOutput=append:/opt/fiery-eyes/logs/snapshot.log
StandardError=append:/opt/fiery-eyes/logs/snapshot.log

[Install]
WantedBy=multi-user.target
